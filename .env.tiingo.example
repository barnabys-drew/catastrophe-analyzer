# Tiingo API (market data). Copy to `.env.tiingo` and set your token.
#   cp .env.tiingo.example .env.tiingo
# Token: https://www.tiingo.com/account/api
# Docs: https://www.tiingo.com/documentation/general/overview
#
# Docker Compose merges extra vars if you pass both files, e.g.:
#   docker compose --env-file .env.agent --env-file .env.tiingo up -d --build
TIINGO_API_TOKEN=
