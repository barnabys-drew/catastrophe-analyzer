# Copy to `.env` for the main `docker compose` stack (Compose reads this file automatically):
#   cp .env.example .env
#
# Market data (when config uses Tiingo): https://www.tiingo.com/account/api
# Optional separate file: `.env.tiingo.example` → `.env.tiingo` and merge with:
#   docker compose --env-file .env --env-file .env.tiingo up -d --build
TIINGO_API_TOKEN=

TZ=UTC

# strict_rules = no LLM; agent = needs CATASTROPHE_ENTITY_AGENT_* when validation uses agent path
CATASTROPHE_ENTITY_VALIDATION_MODE=strict_rules
CATASTROPHE_ENTITY_AGENT_ENDPOINT=
CATASTROPHE_ENTITY_AGENT_API_KEY=
CATASTROPHE_ENTITY_AGENT_PROVIDER=generic_http
CATASTROPHE_ENTITY_AGENT_MODEL=

# Optional email / HTTP overrides (see docker-compose.yml)
# CATASTROPHE_EMAIL_PASSWORD=
# CATASTROPHE_HTTP_USER_AGENT=
