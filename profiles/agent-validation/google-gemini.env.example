# Use an OpenAI-compatible gateway endpoint that routes to Gemini.
CATASTROPHE_ENTITY_VALIDATION_MODE=agent
CATASTROPHE_ENTITY_AGENT_PROVIDER=openai_compatible
CATASTROPHE_ENTITY_AGENT_MODEL=gemini-2.5-flash
CATASTROPHE_ENTITY_AGENT_ENDPOINT=https://your-openai-compatible-gateway.example/v1/chat/completions
CATASTROPHE_ENTITY_AGENT_API_KEY=replace-with-gateway-key
CATASTROPHE_ENTITY_VALIDATION_RUBRIC_FILE=docs/ENTITY_VALIDATION_RUBRIC.md
