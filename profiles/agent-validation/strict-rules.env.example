# Deterministic strict-rule validation only (no LLM / no Ollama).
# Use with Tiingo token file, e.g.:
#   docker compose --env-file profiles/agent-validation/strict-rules.env --env-file .env.tiingo up -d --build
#
# Important: root docker-compose.yml defaults validation mode to "agent" if this is not set.
CATASTROPHE_ENTITY_VALIDATION_MODE=strict_rules
CATASTROPHE_ENTITY_AGENT_ENDPOINT=
CATASTROPHE_ENTITY_AGENT_API_KEY=
CATASTROPHE_ENTITY_VALIDATION_RUBRIC_FILE=docs/ENTITY_VALIDATION_RUBRIC.md
