# Requires Ollama listening on port 11434 BEFORE starting the container, or
# validation will time out / reject candidates (fail_closed) and you get no watches/alerts.
#
# Pick a model you have pulled (`ollama list`). Smaller models are faster; JSON verdict quality varies.
CATASTROPHE_ENTITY_VALIDATION_MODE=agent
CATASTROPHE_ENTITY_AGENT_PROVIDER=ollama
CATASTROPHE_ENTITY_AGENT_MODEL=llama3.2:3b
# Docker → host (compose adds extra_hosts host-gateway on Linux/WSL2):
CATASTROPHE_ENTITY_AGENT_ENDPOINT=http://host.docker.internal:11434/v1/chat/completions
# Native Python on the same machine as Ollama (no Docker):
# CATASTROPHE_ENTITY_AGENT_ENDPOINT=http://127.0.0.1:11434/v1/chat/completions
CATASTROPHE_ENTITY_AGENT_API_KEY=
CATASTROPHE_ENTITY_VALIDATION_RUBRIC_FILE=docs/ENTITY_VALIDATION_RUBRIC.md
