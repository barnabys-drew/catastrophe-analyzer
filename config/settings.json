{
  "event_categories": {
    "cybersecurity": {
      "enabled": true,
      "keywords": [
        "breach",
        "data breach",
        "security breach",
        "hacked",
        "hack",
        "hackers",
        "hacktivist",
        "cyberattack",
        "ransomware",
        "exploit",
        "vulnerability",
        "compromised",
        "attacked",
        "attack",
        "security incident",
        "data exposure",
        "credentials leaked",
        "wiper",
        "wipe",
        "wiped",
        "wiping",
        "data wipe",
        "data-wipe"
      ]
    },
    "leadership_scandal": {
      "enabled": false,
      "keywords": []
    },
    "supply_chain_disruption": {
      "enabled": false,
      "keywords": []
    },
    "clinical_regulatory_binary": {
      "enabled": false,
      "keywords": []
    },
    "product_safety_recall": {
      "enabled": false,
      "keywords": []
    },
    "fraud_accounting_enforcement": {
      "enabled": false,
      "keywords": []
    },
    "financial_distress": {
      "enabled": false,
      "keywords": []
    },
    "dilutive_financing": {
      "enabled": false,
      "keywords": []
    },
    "ma_corporate_action": {
      "enabled": false,
      "keywords": []
    },
    "positive_earnings_catalyst": {
      "enabled": false,
      "keywords": []
    }
  },
  "news_sources": {
    "bleeping_computer": {
      "enabled": true,
      "url": "https://www.bleepingcomputer.com/feed/",
      "event_category": "cybersecurity",
      "update_interval_hours": 6
    },
    "krebs_on_security": {
      "enabled": true,
      "url": "https://krebsonsecurity.com/feed/",
      "event_category": "cybersecurity",
      "update_interval_hours": 12
    },
    "dark_reading": {
      "enabled": false,
      "url": "https://www.darkreading.com/feed/",
      "event_category": "cybersecurity",
      "update_interval_hours": 12
    },
    "techcrunch": {
      "enabled": false,
      "url": "https://techcrunch.com/category/security/feed/",
      "event_category": "cybersecurity",
      "update_interval_hours": 24
    }
  },

  "scraping": {
    "timeout": 10,
    "max_results_per_source": 50,
    "hours_back": 24,
    "retry_on_failure": true,
    "max_retries": 3
  },

  "entity_extraction": {
    "case_sensitive": false,
    "min_company_name_length": 2,
    "fuzzy_matching_enabled": true,
    "fuzzy_match_threshold": 0.8,
    "use_dynamic_lookup": true,
    "lookup_provider": "yfinance",
    "cache_lookups": true,
    "cache_file": "../data/entity_lookup_cache.json"
  },

  "signals": {
    "rsi_oversold_threshold": 30,
    "price_drop_threshold": 10,
    "recovery_days_threshold": 5,
    "volume_spike_threshold": 1.5,
    "min_confidence_for_signal": 0.4,
    "confidence_levels": {
      "high": 0.75,
      "medium": 0.5,
      "low": 0.25
    }
  },

  "stock_analysis": {
    "rsi_period": 14,
    "moving_average_period": 20,
    "volume_spike_period": 20,
    "analysis_window_days": 90,
    "use_mock_data": false,
    "data_source": "yfinance"
  },
  "monitoring_schedule": {
    "scan_interval_minutes": 15,
    "market_hours_only": false,
    "after_hours_scan": true
  },
  "event_watch": {
    "max_days": 7
  },
  "breach_watch": {
    "max_days": 7
  },
  "price_series": {
    "pre_days": 30,
    "post_days": 30
  },

  "backtesting": {
    "enabled": true,
    "min_signal_confidence": "MEDIUM",
    "transaction_cost_percent": 0.1,
    "slippage_percent": 0.05
  },

  "database": {
    "type": "csv",
    "directory": "../data",
    "auto_backup": true,
    "backup_frequency_days": 7
  }
}
