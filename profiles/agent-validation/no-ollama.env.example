# Run Docker without Ollama — deterministic entity validation only (strict_rules).
# Copy to .env.agent or merge into your env file:
#   cp profiles/agent-validation/no-ollama.env.example .env.agent
#
# With agent mode and no reachable LLM, validation fails closed and you will see
# almost no watches, no triage alerts, and no notifications.

CATASTROPHE_ENTITY_VALIDATION_MODE=strict_rules

# Optional: Tiingo for price data (or leave unset to fall back to yfinance)
# TIINGO_API_TOKEN=

# Optional: RSS User-Agent for SEC.gov and other strict feeds (overrides settings.json)
# CATASTROPHE_HTTP_USER_AGENT=CatastropheAnalyzer/1.0 (you@example.com)
