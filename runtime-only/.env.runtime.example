# Runtime-only Docker deployment (no full repo needed)

# Image to run. Use either:
# - locally loaded image: catastrophe-analyzer:latest
# - remote registry image: ghcr.io/<org>/catastrophe-analyzer:latest
CATASTROPHE_IMAGE=catastrophe-analyzer:latest

TZ=UTC

# Validation mode: strict_rules or agent
CATASTROPHE_ENTITY_VALIDATION_MODE=agent

# Agent endpoint (optional unless mode=agent and fallback path triggers)
CATASTROPHE_ENTITY_AGENT_ENDPOINT=
CATASTROPHE_ENTITY_AGENT_API_KEY=
CATASTROPHE_ENTITY_AGENT_PROVIDER=generic_http
CATASTROPHE_ENTITY_AGENT_MODEL=

# Keep shared rubric markdown path stable inside container
CATASTROPHE_ENTITY_VALIDATION_RUBRIC_FILE=docs/ENTITY_VALIDATION_RUBRIC.md

# Tiingo EOD (when config stock_analysis.data_source is tiingo)
TIINGO_API_TOKEN=
