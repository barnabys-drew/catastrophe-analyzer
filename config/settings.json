  "scraping": {
    "timeout": 10,
    "max_results_per_source": 50,
    "hours_back": 24,
    "retry_on_failure": true,
    "max_retries": 3,
    "http_user_agent": ""
  },

  "entity_extraction": {
    "case_sensitive": false,
    "min_company_name_length": 2,
    "fuzzy_matching_enabled": true,
    "fuzzy_match_threshold": 0.8,
    "validation_mode": "agent",
    "use_dynamic_lookup": true,
    "us_listed_equities_only": true,
    "require_exchange_company_verification": true,
    "exchange_verification_fail_closed": true,
    "lookup_provider": "yfinance",
    "cache_lookups": true,
    "cache_file": "../data/entity_lookup_cache.json",
    "agent_validation": {
      "enabled": true,
      "fail_closed": true,
      "timeout_seconds": 8,
      "endpoint": "",
      "api_key": "",
      "provider": "generic_http",
      "model": "",
      "max_candidates_per_article": 5,
      "max_new_validations_per_article": 1,
      "cache_file": "../data/entity_validation_cache.json",
      "cache_ttl_days": 60,
      "rubric_file": "docs/ENTITY_VALIDATION_RUBRIC.md"
    }
  },

  "signals": {
    "rsi_oversold_threshold": 28,
    "price_drop_threshold": 15,
    "require_drop_within_48h": true,
    "drop_within_48h_threshold": 1.0,
    "recovery_days_threshold": 5,
    "volume_spike_threshold": 2.0,
    "min_confidence_for_signal": 0.7,
    "by_category": {
      "cybersecurity": {
        "rsi_oversold_threshold": 28,
        "price_drop_threshold": 15,
        "require_drop_within_48h": true,
        "drop_within_48h_threshold": 1.5,
        "recovery_days_threshold": 5,
        "volume_spike_threshold": 2.0
      },
      "clinical_regulatory_binary": {
        "rsi_oversold_threshold": 30,
        "price_drop_threshold": 12,
        "require_drop_within_48h": true,
        "drop_within_48h_threshold": 1.0,
        "recovery_days_threshold": 4,
        "volume_spike_threshold": 1.8
      },
      "product_safety_recall": {
        "rsi_oversold_threshold": 27,
        "price_drop_threshold": 18,
        "require_drop_within_48h": true,
        "drop_within_48h_threshold": 2.0,
        "recovery_days_threshold": 6,
        "volume_spike_threshold": 2.2
      },
      "fraud_accounting_enforcement": {
        "rsi_oversold_threshold": 29,
        "price_drop_threshold": 14,
        "require_drop_within_48h": true,
        "drop_within_48h_threshold": 1.5,
        "recovery_days_threshold": 5,
        "volume_spike_threshold": 2.0
      }
    },
    "confidence_levels": {
      "high": 0.85,
      "medium": 0.65,
      "low": 0.4
    }
  },
  "distress_model": {
    "min_score_for_watch_default": 50,
    "min_score_for_watch_by_category": {
      "cybersecurity": 50,
      "clinical_regulatory_binary": 60,
      "product_safety_recall": 55,
      "fraud_accounting_enforcement": 58
    }
  },
  "triage": {
    "enabled": true,
    "min_impact_score_for_alert": 60,
    "min_distress_score_for_alert": 35,
    "min_impact_score_for_signal": 75,
    "min_distress_score_for_signal": 60,
    "agent_enabled": true,
    "agent_timeout_seconds": 8,
    "fallback_to_deterministic": true,
    "agent_endpoint": "",
    "agent_api_key": ""
  },

  "stock_analysis": {
    "rsi_period": 14,
    "moving_average_period": 20,
    "volume_spike_period": 20,
    "analysis_window_days": 90,
    "use_mock_data": false,
    "data_source": "tiingo",
    "tiingo_token_env": "TIINGO_API_TOKEN"
  },
  "monitoring_schedule": {
    "scan_interval_minutes": 15,
    "market_hours_only": false,
    "after_hours_scan": true
  },
  "event_watch": {
    "max_days": 7
  },
  "breach_watch": {
    "max_days": 7
  },
  "price_series": {
    "pre_days": 30,
    "post_days": 30
  },

  "backtesting": {
    "enabled": true,
    "min_signal_confidence": "MEDIUM",
    "transaction_cost_percent": 0.1,
    "slippage_percent": 0.05
  },

  "database": {
    "type": "csv",
    "directory": "../data",
    "auto_backup": true,
    "backup_frequency_days": 7
  }
}
